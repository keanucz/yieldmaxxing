# OpenAI (used by Python agents for crop analysis + optimizer)
OPENAI_API_KEY=sk-...

# Sentinel Hub (https://dataspace.copernicus.eu — create OAuth client in dashboard)
SH_CLIENT_ID=your-client-id
SH_CLIENT_SECRET=your-client-secret

# PostgreSQL
DATABASE_URL=postgres://cropguard:cropguard@localhost:5432/cropguard

# Google OAuth2 (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/callback

# App
APP_URL=http://localhost:3000
JWT_SECRET=change-me-to-random-string

# Agent service (internal, used by Go API to call Python agents)
AGENT_SERVICE_URL=http://python-agents:8001

# Mapbox (frontend only, used in test pages)
MAPBOX_TOKEN=pk.eyJ1...
